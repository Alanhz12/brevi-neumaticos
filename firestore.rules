rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /promociones/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /galeria/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}